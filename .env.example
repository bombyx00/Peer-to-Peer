# These are server-only env vars (no VITE_ prefix, never bundled into the client JS).
# Set them in Vercel Project Settings, not just here. Local `vercel dev` picks them up
# via `vercel env pull`.

# Supabase Configuration (server-only — the browser never talks to Supabase directly)
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# App session signing secret (server-only). Generate with: openssl rand -base64 32
APP_JWT_SECRET=replace-with-a-long-random-secret

# Google Sign-In (server-side audience check for ID token verification).
# Same value as VITE_GOOGLE_CLIENT_ID below.
GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com

# Gemini API Configuration (server-only — used by api/gemini-feedback.ts)
GEMINI_API_KEY=your-gemini-api-key

# ---- Client-side env vars (VITE_ prefix, shipped to the browser — keep public-safe only) ----

# Needed client-side to render the Google Sign-In button.
VITE_GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com

# Google Sheets sync (Apps Script Web App proxy — already server-side safe)
VITE_GOOGLE_SHEET_URL=your-google-apps-script-web-app-url
VITE_GOOGLE_SHEET_ID=your-target-spreadsheet-id
VITE_GOOGLE_API_KEY=your-google-api-key
